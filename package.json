{
  "name": "typst-tools",
  "main": "./lib/main",
  "version": "1.0.2",
  "description": "Compile Typst documents with build tools, compile-on-save, and PDF viewer integration",
  "keywords": [
    "typst",
    "typ",
    "typesetting",
    "pdf",
    "compile",
    "watch"
  ],
  "repository": "https://github.com/asiloisad/pulsar-typst-tools",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0"
  },
  "providedServices": {
    "typst-tools": {
      "versions": {
        "1.0.0": "provideTypstTools"
      }
    }
  },
  "consumedServices": {
    "status-bar": {
      "versions": {
        "^1.0.0": "consumeStatusBar"
      }
    },
    "linter-indie": {
      "versions": {
        "2.0.0": "consumeIndie"
      }
    }
  },
  "configSchema": {
    "typstPath": {
      "order": 1,
      "title": "Path to Typst",
      "description": "Path to the typst executable. Leave as 'typst' to use bundled or PATH binary.",
      "type": "string",
      "default": "typst"
    },
    "outputFormat": {
      "order": 2,
      "title": "Output Format",
      "description": "The output format for compilation.",
      "type": "string",
      "default": "pdf",
      "enum": [
        {
          "value": "pdf",
          "description": "PDF - Portable Document Format"
        },
        {
          "value": "png",
          "description": "PNG - Raster image"
        },
        {
          "value": "svg",
          "description": "SVG - Scalable Vector Graphics"
        }
      ]
    },
    "fontPaths": {
      "order": 3,
      "title": "Additional Font Paths",
      "description": "Additional directories to search for fonts.",
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "additionalArgs": {
      "order": 4,
      "title": "Additional Arguments",
      "description": "Additional command-line arguments passed to typst compile/watch.",
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "debug": {
      "order": 99,
      "title": "Debug Mode",
      "description": "Log debug info to developer console (View > Developer > Toggle Developer Tools).",
      "type": "boolean",
      "default": false
    }
  }
}
